{
    "layer": "top",
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["wlr/taskbar", "pulseaudio", "memory", "cpu", "custom/vpn", "network", "idle_inhibitor", "custom/power"],
    "sway/window": {
        "max-length": 50
    },
    "clock": {
        "format": "{:%a, %d. %b  %I:%M}",
        "tooltip": false,
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 14,
        "icon-theme": "Numix-Circle",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "memory": {
        "interval": 30,
        "format": "{used:0.1f}G/{total:0.1f}G <span font_weight='bold'>яГЙ</span>"
    },
    "cpu": {
        "interval": 10,
        "format": "{usage}% <span font_weight='bold'>яЛЫ</span>",
        "max-length": 10
    },
    "idle_inhibitor": {
	      "format": "{icon}",
	      "format-icons": {
	          "activated": "яБо",
	          "deactivated": "яБ░"
	      },
        "timeout": 60
    },
    "network": {
        "interval": 5,
        "format-wifi": "<span font_weight='bold'>яЗл</span>  {essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "<span font_weight='bold'>яГм</span>  {ifname}", // Icon: ethernet
        "format-disconnected": "<span font_weight='bold'>тЪа</span>  Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}",
        "on-click": "alacritty -e 'nmtui'",
    },
    "custom/vpn": {
        "format": "{icon}",
        "exec": "$HOME/.config/waybar/modules/vpn_echo.sh",
        "return-type": "json",
        "tooltip-format": "{}",
        "interval": 5,
        "format-icons": ["яВЬ","яАг"]
    },
    "pulseaudio": {
        "format": "{volume}% <span font_weight='bold'>{icon}</span>  {format_source}",
        "format-bluetooth": "{volume}% <span font_weight='bold'>{icon} яКФ</span>",
        "format-muted": "<span font_weight='bold'>яАж</span>  {format_source}",
        "format-source": "{volume}% <span font_weight='bold'>яД░</span>",
	      "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "ґ░ЛО",
            "headset": "ґ░ЛО",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАз", "яАи"]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "custom/weather": {
        "tooltip": false,
        "exec": "curl 'https://wttr.in/Cleveland?m&format=1'",
        "interval": 800
    },
    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% <span font_weight='bold'>{icon}</span>",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "format-charging": "<span font_weight='bold'>яЗж</span>  {capacity}% - {time}",
        "max-length": 25
    },
    "upower": {
        "format": "{percentage}",
        "format-alt": "{percentage} {time}",
        "icon-size": 20,
        "hide-if-empty": true,
        "tooltip": false,
        "tooltip-spacing": 20
    },
    "custom/power": {
        "format": "<span font_weight='bold'>яАС </span>",
	      "on-click": "swaynag -t warning -m 'Power Menu Options' -b 'Lock' 'swaylock -f -c 000000' -b 'Logout' 'swaymsg exit' -b 'Suspend' 'swaymsg exec systemctl suspend' -b 'Reboot' 'systemctl reboot' -b 'Shutdown' 'systemctl poweroff'"
	  }

}
